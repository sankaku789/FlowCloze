{
  "name": "flowcloze-syntax",
  "displayName": "FlowCloze Syntax",
  "description": "Syntax highlighting for FlowCloze qblock notation in Markdown.",
  "version": "0.0.1",
  "publisher": "flowcloze",
  "engines": {
    "vscode": "^1.80.0"
  },
  "categories": [
    "Programming Languages"
  ],
  "contributes": {
    "grammars": [
      {
        "scopeName": "flowcloze.markdown.injection",
        "path": "./syntaxes/flowcloze.tmLanguage.json",
        "injectTo": [
          "text.html.markdown"
        ]
      }
    ]
  }
}
